            --genome-dir {params.genome_dir} \
            --qc-file {input.qc} \
            --ani-clusters {input.ani_clusters} \
            --panaroo-dir {input.panaroo}
        """

# ========================================
# 阶段 10: 期刊级图表生成
# ========================================
rule generate_figures:
    input:
        tree="results/phylogeny/veillonella_tree_annotated.pdf",
        pan_stats="results/pangenome/pangenome_statistics.pdf",
        ani_heatmap="results/ani/ani_heatmap_clustered.pdf"
    output:
        fig1="figures/Figure1_Phylogeny.pdf",
        fig2="figures/Figure2_Pangenome.pdf",
        fig3="figures/Figure3_ANI_Heatmap.pdf"
    shell:
        """
        echo "=== 整理期刊级图表 ==="
        mkdir -p figures

        # 复制并重命名图表
        cp {input.tree} {output.fig1}
        cp {input.pan_stats} {output.fig2}
        cp {input.ani_heatmap} {output.fig3}

        echo "✓ 图表已保存到 figures/"
        """

